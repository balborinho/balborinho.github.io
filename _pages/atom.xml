---
layout: null
permalink: /atom.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

  <title>Balborinho</title>

  <link href="https://balborinho.com/atom.xml" rel="self"/>
  <link href="https://balborinho.com/"/>

  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>https://balborinho.com/</id>

  <!-- authors -->
  <author>
    <name>Balborinho</name>
    <uri>https://balborinho.com/about/</uri>
  </author>

  <!-- posts -->
  {% for post in site.posts %}
    <entry>
      <title>{{ post.title }}</title>
      <link href="https://balborinho.com{{ post.url }}" />
      <updated>{{ post.date | date_to_xmlschema }}</updated>
      <id>https://balborinho.com{{ post.id }}/</id>
      <content type="html">
        {{ post.content | xml_escape }}
      </content>

      <!-- author -->
      <author>
        {% if post.author %}
        <name>{{ post.author }}</name>
        {% else %}
        <name>Balborinho</name>
        {% endif %}

        {% if post.author contains 'damien' or post.author contains 'Damien' %}
        <uri>https://dmayance.com/</uri>
        {% elsif post.author contains 'matthieu' or post.author contains 'Matthieu' %}
        <uri>https://matthieuoger.com/</uri>
        {% else %}
        <uri>https://balborinho.com/about/</uri>
        {% endif %}
      </author>
    </entry>
  {% endfor %}
</feed>
